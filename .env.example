# Documento 110 — variáveis de ambiente do docker-compose
# Copie para .env (mesma pasta) e preencha. NUNCA comitar o .env real.
#   cp .env.example .env

# Chave de criptografia do n8n (credenciais salvas). OBRIGATÓRIA e fixa —
# se mudar depois, o n8n perde acesso às credenciais já salvas.
# Gere com:  openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Chave para autenticar chamadas à Evolution API (header apikey).
# Qualquer string forte. Gere com:  openssl rand -hex 24
EVOLUTION_API_KEY=
